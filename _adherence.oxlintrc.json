{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/display/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/nyma-backoffice/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Roboto))/i]",
        "message": "Font not provided by the design system. Available: Roboto."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraAlert'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|action|key|ref|className|style|children)$/]",
        "message": "<TiaraAlert> doesn't accept that prop. Declared props: variant, title, action."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraAvatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|initials|size|alt|key|ref|className|style|children)$/]",
        "message": "<TiaraAvatar> doesn't accept that prop. Declared props: src, initials, size, alt."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraAvatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg)$/]",
        "message": "<TiaraAvatar> size must be one of 'xs' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:mode|type|color|size|text|count|key|ref|className|style|children)$/]",
        "message": "<TiaraBadge> doesn't accept that prop. Declared props: mode, type, color, size, text, count."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|lg)$/]",
        "message": "<TiaraBadge> size must be one of 'sm' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraBreadcrumbItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<TiaraBreadcrumbItem> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|leftIcon|rightIcon|loading|key|ref|className|style|children)$/]",
        "message": "<TiaraButton> doesn't accept that prop. Declared props: variant, size, leftIcon, rightIcon, loading."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|headerActions|flat|bodyClassName|key|ref|className|style|children)$/]",
        "message": "<TiaraCard> doesn't accept that prop. Declared props: title, headerActions, flat, bodyClassName."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraCheckbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<TiaraCheckbox> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|accent|onRemove|key|ref|className|style|children)$/]",
        "message": "<TiaraChip> doesn't accept that prop. Declared props: label, accent, onRemove."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraIconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|variant|size|key|ref|className|style|children)$/]",
        "message": "<TiaraIconButton> doesn't accept that prop. Declared props: icon, variant, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:inputSize|state|leftIcon|clearable|onClear|key|ref|className|style|children)$/]",
        "message": "<TiaraInput> doesn't accept that prop. Declared props: inputSize, state, leftIcon, clearable, onClear."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|key|ref|className|style|children)$/]",
        "message": "<TiaraProgressBar> doesn't accept that prop. Declared props: value."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraRadioOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|disabled|key|ref|className|style|children)$/]",
        "message": "<TiaraRadioOption> doesn't accept that prop. Declared props: value, label, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraSelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|disabled|key|ref|className|style|children)$/]",
        "message": "<TiaraSelectOption> doesn't accept that prop. Declared props: value, label, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraSeparator'] > JSXAttribute > JSXIdentifier[name!=/^(?:orientation|key|ref|className|style|children)$/]",
        "message": "<TiaraSeparator> doesn't accept that prop. Declared props: orientation."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraSeparator'] > JSXAttribute[name.name='orientation'] > Literal[value!=/^(?:horizontal|vertical)$/]",
        "message": "<TiaraSeparator> orientation must be one of 'horizontal' | 'vertical'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraSkeleton'] > JSXAttribute > JSXIdentifier[name!=/^(?:shape|width|height|key|ref|className|style|children)$/]",
        "message": "<TiaraSkeleton> doesn't accept that prop. Declared props: shape, width, height."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraSkeleton'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:text|rect|circle)$/]",
        "message": "<TiaraSkeleton> shape must be one of 'text' | 'rect' | 'circle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraSpinner'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|key|ref|className|style|children)$/]",
        "message": "<TiaraSpinner> doesn't accept that prop. Declared props: size."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraStatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|icon|delta|key|ref|className|style|children)$/]",
        "message": "<TiaraStatCard> doesn't accept that prop. Declared props: label, value, icon, delta."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraTab'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<TiaraTab> doesn't accept that prop. Declared props: value, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraTextarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:rows|key|ref|className|style|children)$/]",
        "message": "<TiaraTextarea> doesn't accept that prop. Declared props: rows."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraToggleSwitch'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<TiaraToggleSwitch> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='TiaraTooltip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|key|ref|className|style|children)$/]",
        "message": "<TiaraTooltip> doesn't accept that prop. Declared props: label, children."
      }
    ]
  },
